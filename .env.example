# Copy to .env (gitignored) and fill in. Kalshi RSA API key auth.
# Create an API key in the Kalshi web app -> Settings -> API Keys.
# You get a key id (UUID) and download a private key PEM file.

KALSHI_API_KEY_ID=00000000-0000-0000-0000-000000000000
KALSHI_PRIVATE_KEY_PEM_PATH=/absolute/path/to/kalshi_private_key.pem
